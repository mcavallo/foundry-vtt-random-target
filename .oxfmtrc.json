{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "arrowParens": "always",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "printWidth": 85,
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "trailingComma": "es5",
  "useTabs": false,
  "importOrder": [
    "^(bun|node):.*$",
    "<THIRD_PARTY_MODULES>",
    "^#/(.*)$",
    "^@/(.*)$",
    "^[./]"
  ],
  "importOrderSortSpecifiers": true,
  "sortPackageJson": false,
  "ignorePatterns": ["dist", "CHANGELOG.md"],
  "overrides": [
    {
      "files": ["*.yml", "*.yaml", "*.hbs"],
      "options": {
        "singleQuote": false
      }
    }
  ]
}
